    <!-- Hero Section -->
    <section id="hero" class="relative pt-32 pb-20 px-4 sm:px-6 lg:px-8">
      <!-- Background Pattern -->
      <div class="absolute inset-0 -z-10">
        <div
          class="absolute inset-0 h-full w-full bg-white bg-[linear-gradient(to_right,#f0f0f0_1px,transparent_1px),linear-gradient(to_bottom,#f0f0f0_1px,transparent_1px)] bg-[size:6rem_4rem]"
        >
          <div
            class="absolute inset-0 bg-[radial-gradient(circle_500px_at_50%_200px,#C9EBFF,transparent)]"
          ></div>
        </div>
      </div>
      <div class="max-w-7xl mx-auto">
        <div class="grid md:grid-cols-2  gap-12 items-center">
          <!-- Left Content -->
          <div class="fade-in-left order-2 md:order-1" style="animation-delay: 0s">
            <div class="mb-6">
              <span
                class="inline-block bg-blue-100 text-blue-700 px-4 py-2 rounded-full text-sm font-semibold"
                >Trusted by 5,000+ Businesses</span
              >
            </div>
            <h1
              class="text-5xl md:text-6xl font-bold leading-tight mb-6 text-gray-900"
            >
              If your competitors have more Google reviews than you, they’re taking your customers. Here’s how to fix it automatically
              <!-- <span
                class="bg-gradient-to-r from-blue-600 to-blue-700 bg-clip-text text-transparent"
                >5-Star Reviews!</span
              > -->
            </h1>
            <p class="text-xl text-gray-700 mb-6 leading-relaxed">
              InstaReviewUs helps you get more Google reviews from happy
              customers, while blocking out the negative ones. And yes,
              everything we do complies with Google's guidelines 100%!
            </p>
            <p class="text-lg text-gray-600 mb-8 leading-relaxed">
              We use scan-to-review stickers and tap-to-review stands that make
              it effortless for guests to share feedback in seconds. Happy
              customers are sent straight to your Google page, while unhappy
              ones share feedback privately.
            </p>
            <div class="flex flex-col sm:flex-row  gap-4 mb-12">
              <a href="#pricing" class="flex justify-center items-center">
                <button
                  class="premium-btn text-white md:px-8 px-20 py-3 rounded-lg font-semibold flex justify-center items-center"
                >
                  Check Out Plans
                </button>
              </a>
              <button
                onclick="openVideoModal()"
                class="outline-btn text-blue-600 px-8 py-3 rounded-lg font-semibold"
              >
                See How It Works
              </button>
            </div>
            <div class="space-y-4">
              <p class="flex items-center text-gray-700 font-semibold">
                <span class="text-2xl mr-3">⭐⭐⭐⭐⭐</span>
                Trusted by restaurants, cafés, salons & gyms
              </p>
              <div class="border-l-4 border-blue-600 pl-4">
                <p class="italic text-gray-700 text-lg mb-2">
                  {"Within weeks, we doubled our reviews and protected our
                  rating from unfair 1-stars."}
                </p>
                <p class="font-semibold text-gray-900">
                  — Mike, Ashburns Café Owner
                </p>
              </div>
            </div>
          </div>

          <!-- Right Image -->
