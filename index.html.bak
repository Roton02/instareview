              </li>
            </ul>

            <button class="pricing-btn btn-primary">Choose Pro</button>
          </div>

          <!-- Ultimate Plan -->
          <div class="pricing-card fade-in-up" style="animation-delay: 0.2s">
            <h3 class="pricing-plan-name">Ultimate</h3>
            <p class="pricing-plan-desc">For multi-location businesses</p>

            <div class="pricing-price">
              <span class="dollar">$</span>
              <span class="amount">89.99</span>
              <span class="period">/month</span>
            </div>

            <p class="pricing-onetime">$89.99 One Time Review Starter Kit</p>
            <p class="pricing-included">
              1,000 QR stickers - Custom Setup & Activation
            </p>

            <ul class="pricing-features">
              <li class="included">
                <span class="check-icon">✓</span>
                <span>😊/😐/😞 Routing</span>
              </li>
              <li class="included">
                <span class="check-icon">✓</span>
                <span>Private feedback</span>
              </li>
              <li class="included">
                <span class="check-icon">✓</span>
                <span>Email capture</span>
              </li>
              <li class="included">
                <span class="check-icon">✓</span>
                <span
                  >Incentivize customers to leave a review with an automatic
                  coupon</span
                >
              </li>
              <li class="included">
                <span class="check-icon">✓</span>
                <span>Free table stand</span>
              </li>
              <li class="included">
                <span class="check-icon">✓</span>
                <span
                  >Revive slow hours: send coupons to your customer list in
                  seconds</span
                >
              </li>
            </ul>

            <button class="pricing-btn btn-outline">Choose Ultimate</button>
          </div>
        </div>

        <!-- Sticker Info -->
        <div
          class="bg-white rounded-2xl p-8 md:p-12 fade-in-up border border-blue-200"
        >
          <p class="text-center text-gray-900 font-semibold mb-8 text-lg">
            📌 Sticker Options Included With Your Plan
          </p>
          <div class="grid md:grid-cols-2 gap-8">
            <div>
              <p class="font-bold text-gray-900 mb-3">
                Starter Plan ($49.99/mo)
              </p>
              <p class="text-gray-700">
                You'll receive our Standard Stickers. Happy customers are sent
                to your Google page. Unhappy customers share private feedback
                with you.
              </p>
            </div>
            <div>
              <p class="font-bold text-gray-900 mb-3">
                Pro & Ultimate Plans ($69.99+ /mo)
              </p>
              <p class="text-gray-700">
                You'll receive our Incentivized Stickers. Incentivizes customers
                to leave a review by offering a thank-you coupon that also
                encourages repeat visits.
              </p>
            </div>
          </div>
          <p class="text-center text-gray-700 mt-8 text-sm">
            👉 No need to choose. When you pick your plan, we'll automatically
            send you the correct stickers.
          </p>
        </div>
      </div>
    </section>

    <!-- Testimonials -->
    <section class="py-20 section-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <h2 class="text-4xl md:text-5xl font-bold mb-4">
            What Our Customers Say
          </h2>
          <p class="text-xl text-gray-600">Real results from real businesses</p>
        </div>
        <div class="grid md:grid-cols-3 gap-8">
          <div class="testimonial-card fade-in-up" style="animation-delay: 0s">
            <p class="text-yellow-400 mb-4">⭐⭐⭐⭐⭐</p>
            <p class="text-gray-700 leading-relaxed mb-6">
              "We doubled our 5-star reviews in under a month. The private
              feedback saved us from multiple bad ratings."
            </p>
            <p class="font-bold text-gray-900">Samantha</p>
            <p class="text-gray-600 text-sm">Susu's Dream Cakes</p>
          </div>
          <div
            class="testimonial-card fade-in-up"
            style="animation-delay: 0.1s"
          >
            <p class="text-yellow-400 mb-4">⭐⭐⭐⭐⭐</p>
            <p class="text-gray-700 leading-relaxed mb-6">
              "Customers love how simple it is, they scan, leave feedback, and
              we get more reviews every week."
            </p>
            <p class="font-bold text-gray-900">Ahmed</p>
            <p class="text-gray-600 text-sm">Olives and Figs</p>
          </div>
          <div
            class="testimonial-card fade-in-up"
            style="animation-delay: 0.2s"
          >
            <p class="text-yellow-400 mb-4">⭐⭐⭐⭐⭐</p>
            <p class="text-gray-700 leading-relaxed mb-6">
              "Set up was quick, the dashboard is easy to use, and our online
              reputation has never been better."
            </p>
            <p class="font-bold text-gray-900">David</p>
            <p class="text-gray-600 text-sm">NYC Bagels and Coffee</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Join Us Section -->
    <section id="join-us" class="relative py-20 overflow-hidden">
      <!-- Animated Gradient Background -->
      <div class="animated-bg">
        <div class="gradient-blob blob-1"></div>
        <div class="gradient-blob blob-2"></div>
        <div class="gradient-blob blob-3"></div>
        <div class="gradient-blob blob-4"></div>
        <div class="gradient-blob blob-5"></div>
      </div>
      
      <!-- Floating Particles -->
      <div class="particles">
        <div class="particle particle-1"></div>
        <div class="particle particle-2"></div>
        <div class="particle particle-3"></div>
        <div class="particle particle-4"></div>
        <div class="particle particle-5"></div>
        <div class="particle particle-6"></div>
        <div class="particle particle-7"></div>
        <div class="particle particle-8"></div>
      </div>

      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <!-- Header Text - Top Center -->
        <div class="text-center mb-16 fade-in-up">
          <h2 class="text-5xl md:text-6xl font-bold text-gray-900 mb-6 animate-title">
            Join Us!
          </h2>
          <h3 class="text-2xl md:text-3xl font-semibold text-gray-700 mb-4 animate-subtitle">
            Want to join us? Smart idea!
          </h3>
          <p class="text-lg text-gray-600 leading-relaxed max-w-2xl mx-auto animate-text">
            Please fill in the following form and we will get in touch with you soon.
          </p>
        </div>

        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <!-- Left Side - Enhanced Animation (Desktop only) -->
          <div class="join-us-animation hidden lg:flex items-center justify-center">
            <div class="animated-graphic-enhanced">
              <!-- Rotating Rings -->
              <div class="ring ring-outer"></div>
              <div class="ring ring-middle"></div>
              <div class="ring ring-inner"></div>
              
              <!-- Center Icon with Glow -->
              <div class="center-icon-wrapper">
                <div class="icon-glow"></div>
                <div class="center-icon">
                  <svg width="80" height="80" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M3 8L10.89 13.26C11.2187 13.4793 11.6049 13.5963 12 13.5963C12.3951 13.5963 12.7813 13.4793 13.11 13.26L21 8M5 19H19C19.5304 19 20.0391 18.7893 20.4142 18.4142C20.7893 18.0391 21 17.5304 21 17V7C21 6.46957 20.7893 5.96086 20.4142 5.58579C20.0391 5.21071 19.5304 5 19 5H5C4.46957 5 3.96086 5.21071 3.58579 5.58579C3.21071 5.96086 3 6.46957 3 7V17C3 17.5304 3.21071 18.0391 3.58579 18.4142C3.96086 18.7893 4.46957 19 5 19Z" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </div>
              </div>
              
              <!-- Orbiting Dots -->
              <div class="orbit orbit-1">
                <div class="orbit-dot"></div>
              </div>
              <div class="orbit orbit-2">
                <div class="orbit-dot"></div>
              </div>
              <div class="orbit orbit-3">
                <div class="orbit-dot"></div>
              </div>
            </div>
          </div>

          <!-- Right Side - Contact Form -->
          <div class="join-us-right fade-in-right">
            <form id="feedbackForm" class="join-us-form">
              <div class="form-group-join">
                <label for="name">Name</label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  placeholder="Enter your name"
                  required
                />
              </div>
              
              <div class="form-group-join">
                <label for="businessName">Business Name</label>
                <input
                  type="text"
                  id="businessName"
                  name="businessName"
                  placeholder="Enter your business name"
                  required
                />
              </div>
              
              <div class="form-group-join">
                <label for="phone">Phone</label>
                <input
                  type="tel"
                  id="phone"
                  name="phone"
                  placeholder="Enter your phone"
                  required
                />
              </div>
              
              <div class="form-group-join">
                <label for="email">Email</label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  placeholder="Enter your email ID"
                  required
                />
              </div>
              
              <div class="form-group-join">
                <label for="message">Comments</label>
                <textarea
                  id="message"
                  name="message"
                  placeholder="Tell us more about your business"
                  rows="5"
                  required
                ></textarea>
              </div>
              
              <button type="submit" class="submit-join-btn">
                SUBMIT
              </button>
            </form>
            
            <div id="feedbackSuccess" class="join-us-success" style="display: none;">
              <div class="success-icon-join">✓</div>
              <h3>Thank you for joining us!</h3>
              <p>We've received your information and will get back to you soon.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ Section -->
    <section id="faq" class="py-20 section-light">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <h2 class="text-4xl md:text-5xl font-bold mb-4">
            Frequently Asked Questions
          </h2>
          <p class="text-xl text-gray-600">
            Have a question before getting started?
          </p>
        </div>
        <div class="space-y-4">
          <div class="fade-in-up" style="animation-delay: 0s">
            <button class="accordion-btn" onclick="toggleAccordion(0)">
              <span>Is incentivizing reviews allowed?</span>
              <span class="accordion-icon">▼</span>
            </button>
            <div class="accordion-content" id="faq-0">
              <p class="text-gray-700">
                Yes. We never pay for 5-stars, incentives are triggered only
                after feedback is submitted. This complies with Google's
                guidelines.
              </p>
            </div>
          </div>
          <div class="fade-in-up" style="animation-delay: 0.1s">
            <button class="accordion-btn" onclick="toggleAccordion(1)">
              <span>Do I need any technical setup?</span>
              <span class="accordion-icon">▼</span>
            </button>
            <div class="accordion-content" id="faq-1">
              <p class="text-gray-700">
                No. Your account, stickers, and stands arrive preconfigured and
                ready to use. Just place them where customers can see them.
              </p>
            </div>
          </div>
          <div class="fade-in-up" style="animation-delay: 0.2s">
            <button class="accordion-btn" onclick="toggleAccordion(2)">
              <span>Can I track performance?</span>
              <span class="accordion-icon">▼</span>
            </button>
            <div class="accordion-content" id="faq-2">
              <p class="text-gray-700">
                Yes! Your dashboard shows how many scans, taps, and reviews
                you've received, and which locations perform best.
              </p>
            </div>
          </div>
          <div class="fade-in-up" style="animation-delay: 0.3s">
            <button class="accordion-btn" onclick="toggleAccordion(3)">
              <span>How long does setup take?</span>
              <span class="accordion-icon">▼</span>
            </button>
            <div class="accordion-content" id="faq-3">
              <p class="text-gray-700">
                Most businesses go live the same day their stickers arrive.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Final CTA Section -->
    <section class="py-20 gradient-section text-white">
      <div
        class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center fade-in-up"
      >
        <h2 class="text-4xl md:text-5xl font-bold mb-6">
          Ready to Skyrocket Your 5-Star Reviews?
        </h2>
        <p class="text-xl mb-8 text-blue-100">
          Start your journey today. See real results this week.
        </p>
        <p class="text-lg mb-12 text-blue-100">
          Cancel next month, in 3 or in 10! Literally anytime!
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <button
            class="bg-white text-blue-600 font-semibold py-3 px-8 rounded-lg hover:bg-gray-100 transition hover:scale-105 transform duration-300"
          >
            Get More Reviews Now
          </button>
          <button
            class="border-2 border-white text-white font-semibold py-3 px-8 rounded-lg hover:bg-white hover:bg-opacity-10 transition"
          >
            Book a Demo
          </button>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="bg-gray-900 text-gray-400 py-16">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid md:grid-cols-4 gap-12 mb-12">
          <div>
            <div class="flex items-center gap-2 mb-4">
              <span class="font-bold text-white">InstaReviewUs</span>
            </div>
            <p class="text-sm text-gray-400">
              Turn Feedback into 5-Star Reviews. We help local businesses
              collect more positive reviews, fix issues privately, and build
              stronger online reputations!
            </p>
          </div>
          <div>
            <h4 class="text-white font-semibold mb-4">Product</h4>
            <ul class="space-y-2 text-sm">
              <li>
                <a href="#how-it-works" class="hover:text-white transition"
                  >How It Works</a
                >
              </li>
              <li>
                <a href="#pricing" class="hover:text-white transition"
                  >Pricing</a
                >
              </li>
              <li>
                <a href="#features" class="hover:text-white transition"
                  >Features</a
                >
              </li>
            </ul>
          </div>
          <div>
            <h4 class="text-white font-semibold mb-4">Company</h4>
            <ul class="space-y-2 text-sm">
              <li>
                <a href="#" class="hover:text-white transition">About Us</a>
              </li>
              <li>
                <a href="#join-us" class="hover:text-white transition">Join Us</a>
              </li>
              <li><a href="#" class="hover:text-white transition">Blog</a></li>
            </ul>
          </div>
          <div>
            <h4 class="text-white font-semibold mb-4">Legal</h4>
            <ul class="space-y-2 text-sm">
              <li>
                <a href="#" class="hover:text-white transition"
                  >Privacy Policy</a
                >
              </li>
              <li>
                <a href="#" class="hover:text-white transition"
                  >Terms of Service</a
                >
              </li>
              <li>
                <a href="#" class="hover:text-white transition"
                  >Cookie Policy</a
                >
              </li>
            </ul>
          </div>
        </div>
        <div class="border-t border-gray-800 pt-8 text-center">
          <p class="text-gray-500">
            © 2026 InstaReviewUs. All rights reserved.
          </p>
        </div>
      </div>
    </footer>

    <!-- Scroll to Top Button -->
    <button id="scrollToTopBtn" class="scroll-to-top" title="Go to top">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="32" viewBox="0 0 24 28" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="18 15 12 9 6 15"></polyline>
      </svg>
    </button>

    <!-- EmailJS SDK -->
    <script type="text/javascript" src="https://cdn.jsdelivr.net/npm/@emailjs/browser@4/dist/email.min.js"></script>
    <script src="/js/main.js"></script>
  </body>
</html>
