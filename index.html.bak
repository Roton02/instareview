    <!-- How It Works -->
    <section id="how-it-works" class="how-it-works-section">
      <div class="how-it-works-container">
        <!-- Header -->
        <div class="how-it-works-header">
          <h1 class="how-it-works-title">How it works</h1>
          <p class="how-it-works-subtitle">
            It's Simple for You, and Even Easier for Your Customers
          </p>
        </div>

        <!-- Steps Wrapper with Timeline -->
        <div class="steps-wrapper">
          <!-- Timeline Line -->
          <div class="timeline-line">
            <div class="timeline-progress" id="timelineProgress"></div>
          </div>

          <!-- Step 1 -->
          <div class="step-item fade-in-up" data-step="1">
            <div class="step-content-wrapper">
              <span class="step-badge">Step 1</span>
              <h2 class="step-heading step-heading-large">
                Place the Stickers and Table/Counter Stand
              </h2>
              <p class="step-description">
                On to-go orders, on receipts, each table, or at the front counter.
              </p>
            </div>
            <div class="step-visual-wrapper">
              <div class="step-image-container">
                <img class="step-image" src="/public/step1.png" alt="Place stickers" />
              </div>
            </div>
            <div class="step-number-indicator" data-step-num="1">1</div>
          </div>

          <!-- Step 2 -->
          <div class="step-item reverse fade-in-up" data-step="2">
            <div class="step-visual-wrapper">
              <div class="step-image-container">
                <img class="step-image" src="/public/step2.jpeg" alt="Customers scan" />
              </div>
            </div>
            <div class="step-content-wrapper">
              <span class="step-badge">Step 2</span>
              <h2 class="step-heading">
                Customers Scan & Choose an Emoji
              </h2>
              <p class="step-description">
                Works on any phone, no app required
              </p>
              <div class="step-features-list">
                <p>😊 Happy → Sent to Google for 5-star review</p>
                <p>😐 Neutral → Private feedback form</p>
                <p>😞 Unhappy → Private feedback form</p>
              </div>
            </div>
            <div class="step-number-indicator" data-step-num="2">2</div>
          </div>

          <!-- Step 3 -->
          <div class="step-item reverse fade-in-up" data-step="3">
            <div class="step-visual-wrapper">
              <div class="step-image-container">
                <img class="step-image" src="/public/step3.jpeg" alt="Happy review" />
              </div>
            </div>
            <div class="step-content-wrapper">
              <span class="step-badge">Step 3</span>
              <h2 class="step-heading">
                If the customer presses the happy face, it will take them to the
                review page.
              </h2>
              <div class="step-features-list mt-6">
                <p>😊 Happy → Sent to Google for 5-star review</p>
              </div>
            </div>
            <div class="step-number-indicator" data-step-num="3">3</div>
          </div>

          <!-- Step 4 -->
          <div class="step-item reverse fade-in-up" data-step="4">
            <div class="step-visual-wrapper">
              <div class="step-image-container">
                <img class="step-image" src="/public/step4.jpeg" alt="Private feedback" />
              </div>
            </div>
            <div class="step-content-wrapper">
              <span class="step-badge">Step 4</span>
              <h2 class="step-heading">
                If the customer presses neutral or sad face, it will take them to a
                private submission page. For your eyes only.
              </h2>
              <div class="step-features-list mt-6">
                <p>😐 Neutral → Private feedback form</p>
                <p>😞 Unhappy → Private feedback form</p>
              </div>
            </div>
            <div class="step-number-indicator" data-step-num="4">4</div>
          </div>

          <!-- Step 5 -->
          <div class="step-item fade-in-up" data-step="5">
            <div class="step-content-wrapper">
              <span class="step-badge">Step 5</span>
              <h2 class="step-heading">
                (Pro & Ultimate) Incentivize Guests with a Reward
              </h2>
              <p class="step-description">
                Incentivize customers to leave a review with a coupon
                with an expiration date that'll bring them in again.
              </p>
            </div>
            <div class="step-visual-wrapper">
              <div class="step-image-container with-padding">
                <img class="step-image" src="/public/step5.jpeg" alt="Reward system" />
              </div>
            </div>
            <div class="step-number-indicator" data-step-num="5">5</div>
          </div>

          <!-- Step 6 -->
          <div class="step-item reverse fade-in-up" data-step="6">
            <div class="step-visual-wrapper">
              <div class="step-image-container with-padding">
                <img class="step-image" src="/public/step6.jpeg" alt="Dashboard tracking" />
              </div>
            </div>
            <div class="step-content-wrapper">
              <span class="step-badge">Step 6</span>
              <h2 class="step-heading">
                Track Everything in Your Dashboard
              </h2>
              <p class="step-description">
                📊 See your results in real-time. View reviews, scan data, and
                private customer feedback — all in one clean, simple dashboard.
              </p>
              <div class="step-features-list mt-6">
                <p>✔️ Track how many stickers were scanned</p>
                <p>✔️ See which customers left 5-star reviews</p>
                <p>✔️ Read private feedback instantly</p>
                <p>✔️ Download reports anytime</p>
              </div>
              <p class="step-description step-description-small mt-6">
                🧠 No guessing. Just data that helps you improve faster, sell more,
                and make smarter decisions.
              </p>
            </div>
            <div class="step-number-indicator" data-step-num="6">6</div>
          </div>
        </div>
      </div>

      <div class="mt-20">
        
       <div class="">
        <div class="text-center">
          <h1 class="text-2xl font-bold pb-8">Try it out for yourself</h1>
          <p class="text-center text-grey text-base md:text-[20px] font-medium">
